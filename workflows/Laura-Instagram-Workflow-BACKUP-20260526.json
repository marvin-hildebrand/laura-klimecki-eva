            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [660, 120],
      "id": "fetch-laura-image",
      "name": "Fetch Laura Image Row"
    },
    {
      "parameters": {
        "jsCode": "// Set source image URL and design reference for VALUE posts\nconst parsed = $('Parse Input').item.json;\nconst lauraData = $input.first().json;\nconst supabaseUrl = 'https://bmsflpbhftguohitixjj.supabase.co';\n\n// Get laura image path from DB response\nconst lauraPath = Array.isArray(lauraData) ? lauraData[0]?.storage_path : lauraData?.storage_path;\n\n// Design references for value posts\nconst valueRefs = [\n  'design-references/Value-Post/Bildschirmfoto 2026-05-26 um 13.26.14.png',\n  'design-references/Value-Post/Bildschirmfoto 2026-05-26 um 13.26.35.png',\n  'design-references/Value-Post/Bildschirmfoto 2026-05-26 um 13.26.47.png'\n];\n\n// Pick random design reference\nconst randomRef = valueRefs[Math.floor(Math.random() * valueRefs.length)];\n\nreturn {\n  json: {\n    ...parsed,\n    sourceImageUrl: `${supabaseUrl}/storage/v1/object/public/eva-images/${lauraPath}`,\n    designReferenceUrl: `${supabaseUrl}/storage/v1/object/public/eva-images/${encodeURIComponent(randomRef).replace(/%2F/g, '/')}`\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 120],
      "id": "set-value-source",
      "name": "Set Value Source URL"
    },
    {
      "parameters": {
        "modelId": { "__rl": true, "value": "gpt-4o", "mode": "list", "cachedResultName": "GPT-4o" },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Du bist ein Visual Concept Generator für Instagram Reel Thumbnails.\n\nErstelle einen image_prompt für ein Instagram Reel Thumbnail im Format 9:16 (1080x1920px).\n\nDer Nutzer gibt dir einen Titel und ein Schlüsselwort. Du erhältst auch eine DESIGN-REFERENZ - analysiere deren Stil und übernimm ihn EXAKT.\n\n**SAFE ZONE REGEL:**\nAlle wichtigen Elemente (Gesichter, Text) müssen in der MITTLEREN 60% des Bildes sein.\n\n**STIL (aus Design-Referenz übernehmen):**\n- Farbschema exakt übernehmen\n- Text-Platzierung und Größe übernehmen\n- Layout-Struktur übernehmen\n- Lighting und Atmosphäre übernehmen\n\n**PODCAST-SPEZIFISCH:**\n- Zwei Personen aus dem Referenzbild extrahieren\n- NAHAUFNAHME: Gesichter groß, emotional\n- Laura links, Gast rechts\n\n**TEXT:**\n- KURZE Headline: Maximum 3-7 Wörter\n- SEHR GROSSE Schrift\n- Schlüsselwort hervorgehoben\n\n**OUTPUT:**\nNur den reinen Prompt-Text, max. 100 Wörter."
            },
            {
              "role": "user",
              "content": "=Titel: {{ $json.title }}\nSchlüsselwort: {{ $json.keyword }}\n\nDesign-Referenz URL: {{ $json.designReferenceUrl }}"
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [1100, -120],
      "id": "prompt-podcast",
      "name": "Generate Podcast Prompt"
    },
    {
      "parameters": {
        "modelId": { "__rl": true, "value": "gpt-4o", "mode": "list", "cachedResultName": "GPT-4o" },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Du bist ein Visual Concept Generator für Instagram Reel Thumbnails.\n\nErstelle einen image_prompt für ein Instagram Reel Thumbnail im Format 9:16 (1080x1920px).\n\nDer Nutzer gibt dir einen Titel und ein Schlüsselwort. Du erhältst auch eine DESIGN-REFERENZ - analysiere deren Stil und übernimm ihn EXAKT.\n\n**SAFE ZONE REGEL:**\nAlle wichtigen Elemente (Gesicht, Text) müssen in der MITTLEREN 60% des Bildes sein.\n\n**STIL (aus Design-Referenz übernehmen):**\n- Farbschema exakt übernehmen\n- Text-Platzierung und Größe übernehmen\n- Layout-Struktur übernehmen\n- Lighting und Atmosphäre übernehmen\n\n**VALUE-POST-SPEZIFISCH:**\n- Eine Person (Laura) aus dem Referenzbild\n- NAHAUFNAHME: Gesicht groß, emotional\n- Professionelle Pose\n\n**TEXT:**\n- KURZE Headline: Maximum 3-7 Wörter\n- SEHR GROSSE Schrift\n- Schlüsselwort hervorgehoben\n\n**OUTPUT:**\nNur den reinen Prompt-Text, max. 100 Wörter."
            },
            {
              "role": "user",
              "content": "=Titel: {{ $json.title }}\nSchlüsselwort: {{ $json.keyword }}\n\nDesign-Referenz URL: {{ $json.designReferenceUrl }}"
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [1100, 120],
      "id": "prompt-value",
      "name": "Generate Value Prompt"
    },
    {
      "parameters": {
        "jsCode": "// Combine prompt output with source images\nconst promptItem = $input.first().json;\nconst imagePrompt = promptItem?.message?.content || promptItem?.output?.[0]?.content?.[0]?.text || '';\n\n// Get the source data from the correct branch\nlet sourceData;\ntry {\n  sourceData = $('Set Podcast Source URL').item.json;\n} catch (e) {\n  sourceData = $('Set Value Source URL').item.json;\n}\n\nreturn {\n  json: {\n    postId: sourceData.postId,\n    postType: sourceData.postType,\n    title: sourceData.title,\n    keyword: sourceData.keyword,\n    sourceImageUrl: sourceData.sourceImageUrl,\n    designReferenceUrl: sourceData.designReferenceUrl,\n    imagePrompt,\n    aspectRatio: sourceData.aspectRatio,\n    resolution: sourceData.resolution\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 0],
      "id": "combine-prompt-and-image",
      "name": "Combine Prompt & Image"
