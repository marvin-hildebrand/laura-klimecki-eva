        "body": "={\n  \"input\": {\n    \"prompt\": {{ JSON.stringify($json.imagePrompt) }},\n    \"image\": {{ JSON.stringify($json.sourceImageUrl) }},\n    \"style_image\": {{ JSON.stringify($json.designReferenceUrl) }},\n    \"aspect_ratio\": \"9:16\",\n    \"output_format\": \"jpg\",\n    \"safety_filter_level\": \"block_only_high\"\n  }\n}",
        "options": {}
      },
