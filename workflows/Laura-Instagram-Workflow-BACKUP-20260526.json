    {
      "parameters": {
        "jsCode": "// Set source image URL and design reference for PODCAST posts\nconst parsed = $('Parse Input').item.json;\nconst supabaseUrl = 'https://bmsflpbhftguohitixjj.supabase.co';\n\n// Design references for podcast posts\nconst podcastRefs = [\n  'design-references/Podcast-Post/Bildschirmfoto 2026-05-26 um 13.27.04.png',\n  'design-references/Podcast-Post/Bildschirmfoto 2026-05-26 um 13.27.16.png',\n  'design-references/Podcast-Post/Bildschirmfoto 2026-05-26 um 13.27.37.png'\n];\n\n// Pick random design reference\nconst randomRef = podcastRefs[Math.floor(Math.random() * podcastRefs.length)];\n\nreturn {\n  json: {\n    ...parsed,\n    sourceImageUrl: `${supabaseUrl}/storage/v1/object/public/eva-images/${parsed.guestImagePath}`,\n    designReferenceUrl: `${supabaseUrl}/storage/v1/object/public/eva-images/${encodeURIComponent(randomRef).replace(/%2F/g, '/')}`\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, -120],
      "id": "set-podcast-source",
      "name": "Set Podcast Source URL"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://bmsflpbhftguohitixjj.supabase.co/rest/v1/laura_images",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "id", "value": "=eq.{{ $json.lauraImageId }}" },
