    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json || {};\n\nconst keywordsArr = Array.isArray(body.keywords)\n  ? body.keywords\n  : (body.keyword ? [body.keyword] : []);\n\nreturn {\n  json: {\n    postId: body.postId || null,\n    postType: body.postType,\n    title: (body.title || '').toString(),\n    keyword: keywordsArr.join(' ').toUpperCase(),\n    keywords: keywordsArr,\n    lauraImageId: body.lauraImageId || null,\n    guestImagePath: body.guestImagePath || null,\n    aspectRatio: '9:16',\n    resolution: '2K'\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 0],
